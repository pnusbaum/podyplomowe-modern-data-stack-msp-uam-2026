        'PL' as language_code,
        '0' as author_rating,
        0.0 as book_average_rating,
        0 as book_ratings_count,
        'Unknown' as category,
        0.0 as gross_sales,
        0.0 as publisher_revenue,
        0.0 as price,
        99999 as sales_rank,
        'System' as publisher,
        0 as units_sold
)

SELECT * FROM source
UNION ALL

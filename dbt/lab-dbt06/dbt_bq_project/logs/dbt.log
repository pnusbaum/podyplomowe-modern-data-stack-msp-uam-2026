    create or replace table `pnusbaum-uam-2026`.`bookstore_dwh`.`metrics_daily_sales`
      
    
    

    
    OPTIONS()
    as (
      SELECT
    transaction_date,
    COUNT(DISTINCT transaction_id) as total_transactions,
    COUNT(DISTINCT customer_id) as total_customers,
    SUM(quantity) as total_items_sold,
    SUM(total_item_price) as total_revenue
FROM `pnusbaum-uam-2026`.`bookstore_dwh`.`fct_transactions`
GROUP BY 1
ORDER BY 1 DESC
    );
  
10:06:56.977578 [debug] [Thread-2 (]: Writing runtime sql for node "model.dbt_bq_project.report_monthly_book_ranking"
10:06:56.978692 [debug] [Thread-2 (]: On model.dbt_bq_project.report_monthly_book_ranking: /* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "dbt_bq_project", "target_name": "dev", "node_id": "model.dbt_bq_project.report_monthly_book_ranking"} */

  
    

    create or replace table `pnusbaum-uam-2026`.`bookstore_semantic`.`report_monthly_book_ranking`
      
    
    

    
    OPTIONS()
    as (
      -- models/semantic/report_monthly_book_ranking.sql


WITH monthly_sales AS (
    SELECT
        FORMAT_DATE('%Y-%m', transaction_date) as sales_month,
        book_id,
        book_title,
        SUM(total_item_price) as total_revenue,
        SUM(quantity) as total_units_sold
    FROM `pnusbaum-uam-2026`.`bookstore_dwh`.`fct_transactions`
    GROUP BY 1, 2, 3
),

ranked_books AS (
    SELECT
        *,
        RANK() OVER (PARTITION BY sales_month ORDER BY total_units_sold DESC) as monthly_rank
    FROM monthly_sales
)

SELECT * FROM ranked_books
ORDER BY sales_month DESC, monthly_rank ASC
    );
  
